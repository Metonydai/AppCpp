# ==========================================
# 1. 建置產物與暫存資料夾 (CMake & MSBuild)
# ==========================================
build/
build-arm64/
.cache/
out/

# ==========================================
# 2. 套件管理器與依賴庫 (vcpkg)
# ==========================================
# 排除 vcpkg 下載與編譯好的本機套件（Manifest 模式會產在 build/，全域則排除此處）
vcpkg_installed/
# 如果你把 vcpkg 整個當作 git 子模組，通常不需要排除；但如果是放壓縮檔源碼，可視情況排除
# third_party/vcpkg/

# ==========================================
# 3. IDE 編輯器特定設定檔
# ==========================================
# Visual Studio
.vs/
*.user
*.suo
*.sln.docstates

# VS Code
.vscode/
# 排除本機端自動產生的 CMake Preset 使用者覆蓋檔
CMakeUserPresets.json

# CLion / JetBrains
.idea/
cmake-build-*/

# ==========================================
# 4. 編譯輸出的二進位檔案
# ==========================================
*.exe
*.dll
*.so
*.dylib
*.pyd
*.lib
*.a
*.pdb

# ==========================================
# 5. 其他系統與日誌檔案
# ==========================================
*.log
.DS_Store
Thumbs.db